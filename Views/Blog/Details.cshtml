@model BlogPostApplication.Models.Post

@{
    ViewData["Title"] = Model?.Title ?? "Champion Details";
}

<div class="container mt-5">
    @if (Model == null)
    {
        <div class="alert alert-danger">
            <h4>Champion Not Found</h4>
            <p>The champion you are looking for does not exist.</p>
            <a href="@Url.Action("Index", "Blog")" class="btn btn-primary">Back to Champions</a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <article>
                    <div class="mb-4">
                        <img src="@Model.ImageUrl" alt="@Model.Title" class="img-fluid rounded shadow-lg" style="width: 100%; max-height: 500px; object-fit: cover;">
                    </div>
                    <header class="mb-4">
                        <h1 class="display-4">⚔️ @Model.Title</h1>
                        <div class="mb-3">
                            <span class="badge bg-primary me-2">@Model.Role</span>
                            <span class="badge bg-secondary me-2">@Model.Type</span>
                            <span class="badge bg-warning text-dark me-2">Difficulty: @Model.Difficulty</span>
                        </div>
                        <div class="text-muted mt-3">
                            <p>
                                <strong>Champion Class:</strong> @Model.Author
                            </p>
                            <hr />
                        </div>
                    </header>

                    <div class="champion-content">
                        <h4>Champion Information</h4>
                        <p>@Model.Content</p>

                        <div class="card mt-4 bg-light">
                            <div class="card-body">
                                <h5 class="card-title">Champion Stats</h5>
                                <ul class="list-unstyled">
                                    <li><strong>Role:</strong> @Model.Role</li>
                                    <li><strong>Champion Type:</strong> @Model.Type</li>
                                    <li><strong>Class:</strong> @Model.Author</li>
                                    <li><strong>Difficulty Level:</strong> @Model.Difficulty</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <footer class="mt-5 pt-4 border-top">
                        <a href="@Url.Action("Index", "Blog")" class="btn btn-secondary">← Back to Champions</a>
                    </footer>
                </article>
            </div>
        </div>
    }
</div>

<style>
    .champion-content {
        line-height: 1.8;
        font-size: 1.1rem;
    }
</style>
