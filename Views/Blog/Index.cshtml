@model IEnumerable<BlogPostApplication.Models.Post>

@{
    ViewData["Title"] = "League of Legends Champions";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1>🎮 League of Legends Champions</h1>
            <p class="lead text-muted">Discover the champions of League of Legends</p>
            <hr />
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No champions available. Please check back later!
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var champion in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card h-100 shadow-sm champion-card">
                        <div class="position-relative">
                            <img src="@champion.ImageUrl" class="card-img-top champion-image" alt="@champion.Title" style="height: 300px; object-fit: cover;">
                            <div class="position-absolute top-0 end-0 m-2">
                                <span class="badge bg-warning text-dark">@champion.Difficulty</span>
                            </div>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">
                                <a href="@Url.Action("Details", "Blog", new { id = champion.Id })" class="text-decoration-none">
                                    ⚔️ @champion.Title
                                </a>
                            </h5>
                            <div class="mb-3">
                                <div class="badge bg-primary me-2">@champion.Role</div>
                                <div class="badge bg-secondary me-2">@champion.Type</div>
                            </div>
                            <p class="card-text">
                                <strong>Class:</strong> @champion.Author
                            </p>
                            <p class="card-text text-muted">
                                @(champion.Content.Length > 120 ? champion.Content.Substring(0, 120) + "..." : champion.Content)
                            </p>
                        </div>
                        <div class="card-footer bg-white border-top-0">
                            <a href="@Url.Action("Details", "Blog", new { id = champion.Id })" class="btn btn-sm btn-primary">
                                View Champion →
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .champion-card {
        transition: transform 0.2s, box-shadow 0.2s;
        border: 2px solid #f0f0f0;
    }
    
    .champion-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15) !important;
        border-color: #0d6efd;
    }
</style>
